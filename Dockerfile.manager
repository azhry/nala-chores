FROM golang:1.22-bookworm AS build

WORKDIR /src
COPY go.mod ./
COPY cmd/ ./cmd/
COPY internal/ ./internal/
RUN CGO_ENABLED=0 go build -o /out/runner-manager ./cmd/runner-manager

FROM alpine:3.20
RUN apk add --no-cache ca-certificates kubectl
RUN adduser -D -u 65532 runner
COPY --from=build /out/runner-manager /runner-manager
USER runner
ENTRYPOINT ["/runner-manager"]
